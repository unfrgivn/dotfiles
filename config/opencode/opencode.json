{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"]
    }
    // "miro-mcp": {
    //  "type": "remote",
    //  "url": "https://mcp.miro.com/",
    //  "oauth": {}
    //}
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "permission": {
    "lsp": "allow",
    "question": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "external_directory": {
      "~/.cache/opencode/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@wpro-eng/opencode-config"
  ]
  //"plugin": ["/Users/bash/Sites/wpromote/opencode-config"]
  // "plugin": ["@wpro-eng/opencode-config@v1.15.0"]
}
